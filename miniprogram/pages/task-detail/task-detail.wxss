.detail-page {
  padding-bottom: 80rpx;
}

.detail-card {
  padding: 30rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.3;
}

.status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.status.pending {
  background: #f1f5f9;
  color: #475569;
}

.status.doing {
  background: #fffbeb;
  color: #b45309;
}

.status.review {
  background: #eff6ff;
  color: #1d4ed8;
}

.status.done {
  background: #ecfdf5;
  color: #047857;
}

.meta-line,
.time-line {
  margin-top: 16rpx;
  color: #64748b;
  font-size: 26rpx;
}

.tag {
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #ecfeff;
  color: #0f766e;
  font-size: 20rpx;
  vertical-align: 3rpx;
}

.section {
  margin-top: 20rpx;
  padding: 28rpx;
}

.section-title {
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.section-body {
  color: #334155;
  font-size: 27rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.action-button {
  margin-top: 28rpx;
}
