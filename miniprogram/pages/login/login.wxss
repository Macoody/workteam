.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 32rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 12rpx 6rpx;
}

.brand-mark {
  width: 88rpx;
  height: 88rpx;
  display: grid;
  place-items: center;
  border-radius: 26rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
}

.brand-title {
  font-size: 40rpx;
  font-weight: 900;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 26rpx;
}

.login-card {
  padding: 34rpx;
}

.card-title {
  margin-bottom: 28rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.divider {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 18rpx;
  margin: 30rpx 0;
  color: #94a3b8;
  font-size: 24rpx;
}

.divider text {
  height: 1rpx;
  background: #e2e8f0;
}

.form-field {
  margin-bottom: 22rpx;
}

.form-field text {
  display: block;
  margin-bottom: 10rpx;
  color: #475569;
  font-size: 26rpx;
  font-weight: 700;
}

.form-field input {
  height: 84rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border: 1rpx solid #dbe3ee;
  border-radius: 16rpx;
  background: #f8fafc;
  font-size: 28rpx;
}

.bind-button {
  height: 76rpx;
  margin-top: 18rpx;
  border-radius: 16rpx;
  background: #ecfeff;
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.disabled-button {
  background: #f1f5f9;
  color: #94a3b8;
}

.login-message {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.login-message.info {
  background: #eff6ff;
  color: #1d4ed8;
}

.login-message.error {
  background: #fef2f2;
  color: #dc2626;
}
