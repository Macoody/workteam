# WorkTeam 生产环境配置
#
# 1. 复制为 .env：
#      cp .env.example .env
# 2. 填好下面两行（DATABASE_URL 已经有了，SECRET_KEY 你生成一个）
# 3. 改 .env 权限：
#      chmod 600 .env
# 4. docker-compose 启动时会自动读取

# === 数据库（Supabase PostgreSQL）===
DATABASE_URL=postgresql+psycopg://postgres:YOUR_SUPABASE_PASSWORD@db.gpurcghatfhuwgzenloy.supabase.co:5432/postgres

# === JWT 密钥（必填，至少 32 字符）===
# 在服务器上执行下面这条命令生成，把它粘贴到下一行：
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-output-of-secrets-token_urlsafe-48

# === 业务时区 ===
BUSINESS_TIMEZONE=Asia/Shanghai
UPLOAD_DIR=/app/uploads
