# WorkTeam / 徐东摆地摊 - 环境变量样例
# 复制为 .env 后填入实际值。.env 已被 .gitignore 忽略，不会被提交。

# === 数据库（必填）===
# PostgreSQL 连接串（Supabase 或自建均可）
# 示例: postgresql+psycopg://postgres:your_password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg://postgres:your_password@db.your-project.supabase.co:5432/postgres

# === JWT 密钥（必填，至少 32 字符）===
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# === 可选配置（已有合理默认值，通常无需改）===
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=104857600
# BUSINESS_TIMEZONE=Asia/Shanghai

# === 微信小程序登录 ===
# 正式小程序联调时填写，后端会用 wx.login 的 code 换取 openid。
# WECHAT_MINI_APP_ID=wx_your_app_id
# WECHAT_MINI_APP_SECRET=your_app_secret
# 仅本地开发时可打开，用 dev_openid 绕过微信 code2Session。
# WECHAT_DEV_LOGIN_ENABLED=false

# === 前端本地开发可选 ===
# 如果后端不用 8001 端口，启动前端时可指定：
# VITE_API_PROXY_TARGET=http://127.0.0.1:8011
